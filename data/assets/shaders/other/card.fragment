#version 460 core

in vec3 vNormals;
in vec2 vBackTexCoords;
in vec2 vSymbTexCoords;
in flat int vInstanceID;

out vec4 FragColor;

uniform sampler2DArray uAtlas;

void main() {

	vec4 back_tex = texture(uAtlas, vec3(vBackTexCoords, 0.0));
    vec4 symb_tex = texture(uAtlas, vec3(vSymbTexCoords, 0.0));
	vec3 colorRGB = mix (back_tex.rgb, symb_tex.rgb, symb_tex.a);
    float colorAlpha = max (back_tex.a, symb_tex.a);
    FragColor = vec4 (colorRGB, colorAlpha);
};