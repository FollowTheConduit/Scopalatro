#version 460 core

out vec4 FragColor;
  
in vec2 vTexCoords;

uniform sampler2D uFrame;

const float threshold = 0.1;
void main() {
	vec3 color = texture (uFrame, vTexCoords).xyz;

	if (color.r < threshold && color.g < threshold && color.b < threshold) {
		color = vec3 (0.0);
	}
	else {
		color = vec3 (1.0);
	}

	FragColor = vec4 (color, 1.0);
}